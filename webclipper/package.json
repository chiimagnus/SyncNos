{
  "name": "webclipper",
  "private": true,
  "version": "2003.08.20",
  "description": "WebClipper browser extension (Chromium/Edge + Firefox)",
  "type": "commonjs",
  "scripts": {
    "dev": "wxt --mv3",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build --mv3",
    "build:firefox": "wxt build -b firefox --mv3",
    "prepare": "wxt prepare",
    "compile": "tsc -p tsconfig.compile.json --noEmit",
    "check": "npm run build && node ../.github/scripts/webclipper/check-dist.mjs --root=webclipper/.output/chrome-mv3",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "gate": "npm run lint && npm run format:check && npm run compile && npm run test && npm run build",
    "gate:ci": "npm run lint && npm run format:check && npm run compile && npm run test"
  },
  "prettier": {
    "singleQuote": true,
    "semi": true,
    "trailingComma": "all",
    "printWidth": 120,
    "tabWidth": 2
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^2.1.9",
    "@wxt-dev/module-react": "^1.1.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "fake-indexeddb": "^6.2.2",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.31.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.26.1",
    "vitest": "^2.1.8",
    "wxt": "^0.20.18"
  },
  "dependencies": {
    "@gorhill/ubo-core": "^0.1.30",
    "dom-anchor-text-position": "5.0.0",
    "dom-anchor-text-quote": "1.3.1",
    "fflate": "^0.8.2",
    "katex": "^0.16.38",
    "lucide-react": "^0.541.0",
    "markdown-it": "^14.1.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-texmath": "^1.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "7.13.1",
    "react-tooltip": "^5.30.0",
    "recharts": "^3.8.0",
    "turndown": "^7.2.4"
  }
}
