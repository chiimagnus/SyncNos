    "Use OAuth to authorize SyncNos to access your Notion workspace. This is the recommended method." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brug OAuth til at autorisere SyncNos til at få adgang til dit Notion arbejdsområde. Dette er den anbefalede metode."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verwenden Sie OAuth, um SyncNos den Zugriff auf Ihren Notion-Arbeitsbereich zu autorisieren. Dies ist die empfohlene Methode."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
