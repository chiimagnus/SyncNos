    "Adjust the text size for the app. This setting affects all text throughout the application." : {
      "comment" : "An explanation of what the text size settings do.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Juster tekststørrelsen for appen. Denne indstilling påvirker al tekst i hele applikationen."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Passen Sie die Textgröße für die App an. Diese Einstellung wirkt sich auf den gesamten Text in der Anwendung aus."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajusta el tamaño del texto de la aplicación. Esta configuración afecta a todo el texto de la aplicación."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Säädä sovelluksen tekstin kokoa. Tämä asetus vaikuttaa kaikkeen sovelluksen tekstiin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajustez la taille du texte pour l'application. Ce paramètre affecte tout le texte de l'application."
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sesuaikan ukuran teks untuk aplikasi. Pengaturan ini memengaruhi semua teks di seluruh aplikasi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アプリのテキストサイズを調整します。この設定はアプリ全体のテキストに影響します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "앱의 텍스트 크기를 조정합니다. 이 설정은 앱 전체의 모든 텍스트에 적용됩니다."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pas de tekstgrootte voor de app aan. Deze instelling is van invloed op alle tekst in de applicatie."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajuste o tamanho do texto do aplicativo. Esta configuração afeta todo o texto em todo o aplicativo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Настройте размер текста для приложения. Эта настройка влияет на весь текст в приложении."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Justera textstorleken för appen. Denna inställning påverkar all text i hela applikationen."
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ปรับขนาดตัวอักษรสำหรับแอป การตั้งค่านี้มีผลต่อข้อความทั้งหมดในแอปพลิเคชัน"
