{
  "name": "webclipper",
  "private": true,
  "version": "0.1.0",
  "description": "WebClipper Chrome extension (ChatGPT + NotionAI) MVP",
  "type": "commonjs",
  "scripts": {
    "check": "node scripts/check.mjs",
    "check:dist:firefox": "node scripts/check.mjs --root=dist-firefox --no-syntax",
