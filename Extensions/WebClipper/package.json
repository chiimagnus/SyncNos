{
  "name": "webclipper",
  "private": true,
  "version": "0.14.6",
  "description": "WebClipper browser extension (Chromium/Edge + Firefox)",
  "type": "commonjs",
  "scripts": {
    "check": "node scripts/check.mjs",
    "check:dist:edge": "node scripts/check.mjs --root=dist-edge --no-syntax",
    "check:dist:firefox": "node scripts/check.mjs --root=dist-firefox --no-syntax",
    "test": "vitest run",
    "build": "node scripts/build.mjs",
    "build:edge": "node scripts/build.mjs --target=edge --out=dist-edge --zip --zip-name=SyncNos-WebClipper-edge.zip",
    "build:firefox": "node scripts/build.mjs --target=firefox --zip",
    "package:amo-source": "node scripts/package-amo-source.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fake-indexeddb": "^6.2.2",
    "jsdom": "^28.1.0",
    "terser": "^5.31.6",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  }
}
