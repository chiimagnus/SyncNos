{
  "name": "webclipper",
  "private": true,
  "version": "0.14.6",
  "description": "WebClipper browser extension (Chromium/Edge + Firefox)",
  "type": "commonjs",
  "scripts": {
    "dev": "wxt --mv3",
    "dev:firefox": "wxt -b firefox --mv3",
    "build": "wxt build --mv3",
    "build:firefox": "wxt build -b firefox --mv3",
    "prepare": "wxt prepare",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "check": "npm run build && node scripts/check.mjs --root=.output/chrome-mv3",
    "check:dist:edge": "node scripts/check.mjs --root=dist-edge",
    "check:dist:firefox": "node scripts/check.mjs --root=dist-firefox",
    "test": "vitest run",
    "legacy:build": "node scripts/build.mjs",
    "legacy:build:edge": "node scripts/build.mjs --target=edge --out=dist-edge --zip --zip-name=SyncNos-WebClipper-edge.zip",
    "legacy:build:firefox": "node scripts/build.mjs --target=firefox --zip",
    "package:amo-source": "node scripts/package-amo-source.mjs"
  },
  "devDependencies": {
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@wxt-dev/module-react": "^1.1.5",
    "autoprefixer": "^10.4.21",
    "fake-indexeddb": "^6.2.2",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "terser": "^5.31.6",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8",
    "wxt": "^0.20.18"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "7.13.1"
  }
}
