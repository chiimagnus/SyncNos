    "package:amo-source": "node scripts/package-amo-source.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "terser": "^5.31.6",
    "vitest": "^2.1.8"
  },
  "dependencies": {}
}
