{
  "manifest_version": 3,
  "name": "SyncNos-WebClipper",
  "version": "0.1.0",
  "description": "Clip AI chats (ChatGPT, NotionAI) into local storage, export, and sync to Notion.",
  "action": {
    "default_title": "SyncNos-WebClipper",
    "default_popup": "src/ui/popup/popup.html"
  },
  "background": {
    "service_worker": "src/bootstrap/background.js"
  },
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://www.chatgpt.com/*",
    "https://*.notion.so/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://www.chatgpt.com/*",
        "https://*.notion.so/*"
      ],
      "css": ["src/ui/inpage/inpage.css"],
      "js": [
        "src/shared/normalize.js",
        "src/storage/incremental-updater.js",
        "src/collectors/runtime-observer.js",
        "src/collectors/chatgpt-collector.js",
        "src/collectors/notionai-collector.js",
        "src/bootstrap/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
