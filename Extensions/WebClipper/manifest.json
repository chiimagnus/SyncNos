{
  "manifest_version": 3,
  "name": "SyncNos-AI+Web Clipper",
  "version": "0.17.5",
  "description": "Clip AI chats to local storage, export to JSON or Markdown, and sync to Notion on demand.",
  "action": {
    "default_title": "SyncNos-WebClipper",
    "default_popup": "src/ui/popup/popup.html"
  },
  "background": {
    "service_worker": "src/bootstrap/background.js"
  },
  "permissions": ["storage", "downloads", "tabs", "webNavigation", "activeTab", "scripting"],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*",
    "https://www.chatgpt.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://chat.deepseek.com/*",
    "https://chat.z.ai/*",
    "https://kimi.moonshot.cn/*",
    "https://kimi.com/*",
    "https://*.kimi.com/*",
    "https://www.doubao.com/*",
    "https://yuanbao.tencent.com/*",
    "https://poe.com/*",
    "https://*.notion.so/*",
    "https://*.notionusercontent.com/*",
    "https://img.notionusercontent.com/*",
    "https://api.notion.com/*",
    "https://syncnos-notion-oauth.chiimagnus.workers.dev/*",
    "https://chiimagnus.github.io/*",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://www.chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.z.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://kimi.com/*",
        "https://*.kimi.com/*",
        "https://www.doubao.com/*",
        "https://yuanbao.tencent.com/*",
        "https://poe.com/*",
        "https://*.notion.so/*"
      ],
      "css": ["src/ui/styles/tokens.css", "src/ui/styles/flash-ok.css", "src/ui/styles/inpage.css"],
      "js": [
        "src/protocols/message-contracts.js",
        "src/shared/normalize.js",
        "src/shared/runtime-client.js",
        "src/storage/incremental-updater.js",
        "src/collectors/collector-contract.js",
        "src/collectors/registry.js",
        "src/collectors/runtime-observer.js",
        "src/collectors/collector-utils.js",
        "src/collectors/chatgpt/chatgpt-markdown.js",
        "src/collectors/chatgpt/chatgpt-collector.js",
        "src/collectors/claude/claude-collector.js",
        "src/collectors/gemini/gemini-markdown.js",
        "src/collectors/gemini/gemini-collector.js",
        "src/collectors/deepseek/deepseek-markdown.js",
        "src/collectors/deepseek/deepseek-collector.js",
        "src/collectors/zai/zai-markdown.js",
        "src/collectors/zai/zai-collector.js",
        "src/collectors/kimi/kimi-markdown.js",
        "src/collectors/kimi/kimi-collector.js",
        "src/collectors/doubao/doubao-markdown.js",
        "src/collectors/doubao/doubao-collector.js",
        "src/collectors/yuanbao/yuanbao-markdown.js",
        "src/collectors/yuanbao/yuanbao-collector.js",
        "src/collectors/poe/poe-markdown.js",
        "src/collectors/poe/poe-collector.js",
        "src/collectors/notionai/notionai-markdown.js",
        "src/collectors/notionai/notionai-collector.js",
        "src/integrations/notionai-model-picker.js",
        "src/ui/inpage/inpage-tip.js",
        "src/ui/inpage/inpage-button.js",
        "src/bootstrap/content-controller.js",
        "src/bootstrap/content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "exclude_matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://www.chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.z.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://kimi.com/*",
        "https://*.kimi.com/*",
        "https://www.doubao.com/*",
        "https://yuanbao.tencent.com/*",
        "https://poe.com/*",
        "https://*.notion.so/*"
      ],
      "css": ["src/ui/styles/tokens.css", "src/ui/styles/flash-ok.css", "src/ui/styles/inpage.css"],
      "js": [
        "src/protocols/message-contracts.js",
        "src/shared/normalize.js",
        "src/shared/runtime-client.js",
        "src/collectors/collector-contract.js",
        "src/collectors/registry.js",
        "src/collectors/runtime-observer.js",
        "src/ui/inpage/inpage-tip.js",
        "src/ui/inpage/inpage-button.js",
        "src/collectors/web/web-collector.js",
        "src/bootstrap/content-controller.js",
        "src/bootstrap/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon-128.png"],
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*",
        "https://www.chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://chat.deepseek.com/*",
        "https://chat.z.ai/*",
        "https://kimi.moonshot.cn/*",
        "https://kimi.com/*",
        "https://*.kimi.com/*",
        "https://www.doubao.com/*",
        "https://yuanbao.tencent.com/*",
        "https://poe.com/*",
        "https://*.notion.so/*",
        "http://*/*",
        "https://*/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
